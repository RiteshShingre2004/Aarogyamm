# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id


# App Version
VITE_APP_VERSION=1.0.0

# ── Firebase Cloud Functions: OTP Email ──────────────────────────────────────
# Used by the sendOtp Cloud Function to send verification emails via Gmail.
# GMAIL_USER: the Gmail address emails are sent FROM (e.g. yourapp@gmail.com)
# GMAIL_PASS: a Gmail App Password (NOT your real password!)
#   → Generate one at: Google Account → Security → 2-Step Verification → App Passwords
#   → Give it any name (e.g. "Aarogyam") and copy the 16-character code
# Set these as Firebase secrets before deploying functions:
#   firebase functions:secrets:set GMAIL_USER
#   firebase functions:secrets:set GMAIL_PASS
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=your-16-char-app-password
